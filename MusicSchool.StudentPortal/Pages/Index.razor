@page "/"
@namespace MusicSchool.StudentPortal.Pages

@using MusicSchool.StudentPortal.Auth
@using Microsoft.AspNetCore.WebUtilities

@inject TokenService TokenSvc
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Music School — Student Portal</PageTitle>

@if (_invalid)
{
    <MudPaper Class="pa-6 mt-6" Elevation="1"
              Style="max-width:480px; margin:auto; border-top:4px solid #B71C1C;">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.LinkOff"
                     Style="font-size:3rem; color:#B71C1C;" />
            <MudText Typo="Typo.h6" Style="font-weight:700; color:#3A3A3A;">
                Invalid or Missing Link
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                This link is not valid. Please ask your teacher to send you a new portal link.
            </MudText>
        </MudStack>
    </MudPaper>
}

@code {
    private bool _invalid;

    protected override async Task OnInitializedAsync()
    {
        // 1. Already have a token in memory (e.g. navigated back to "/")
        if (!string.IsNullOrEmpty(TokenSvc.Token))
        {
            Nav.NavigateTo("/dashboard", replace: true);
            return;
        }

        // 2. Try to restore from sessionStorage (page refresh)
        var stored = await JS.InvokeAsync<string?>("sessionStorage.getItem", "magic_token");
        if (!string.IsNullOrEmpty(stored))
        {
            TokenSvc.SetToken(stored);
            Nav.NavigateTo("/dashboard", replace: true);
            return;
        }

        // 3. Extract ?token= from the URL query string
        var query = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
        if (query.TryGetValue("token", out var tokenValues) && !string.IsNullOrEmpty(tokenValues))
        {
            var token = tokenValues.ToString();
            await JS.InvokeVoidAsync("sessionStorage.setItem", "magic_token", token);
            TokenSvc.SetToken(token);
            Nav.NavigateTo("/dashboard", replace: true);
            return;
        }

        _invalid = true;
    }
}
